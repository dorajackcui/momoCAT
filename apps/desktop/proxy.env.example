# Main-process environment overrides loaded at startup.
# Proxy settings for OpenAI API requests:
# You can use either plain KEY=VALUE or export KEY=VALUE
HTTPS_PROXY=http://127.0.0.1:7890
HTTP_PROXY=http://127.0.0.1:7890
ALL_PROXY=http://127.0.0.1:7890

# AI prompt debug logging (prints systemPrompt/userPrompt to the main-process console)
# CAT_AI_DEBUG_PROMPTS=1
